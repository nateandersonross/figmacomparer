# Personal access token from Figma → Settings → Security
FIGMA_ACCESS_TOKEN=

# Optional: default token for the UI (users can override per run)
NEXT_PUBLIC_APP_NAME=FigmaComparer

# MySQL — optional. When set, flagged issues are persisted and re-loaded
# automatically the next time you capture the same dev URL.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
